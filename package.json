{
  "name": "redalert-telegram-bot",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Telegram bot for Israel RedAlert emergency alerts, powered by Claude AI and MCP",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t redalert-bot .",
    "docker:run": "docker run --env-file .env redalert-bot",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pino": "^9.0.0",
    "telegraf": "^4.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
